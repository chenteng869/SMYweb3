  currency            String    @default("USD")
  shareholders         String?   // JSON: [{name,type,shares,nationality}...]
  directors           String?   // JSON: [{name,nationality}...]
  registeredAgent     String?   // 注册代理人/秘书公司
  registeredAddress   String?
  businessScope       String?
  status              String    @default("pending")
  progress            Int       @default(0)
  progressSteps       String?
  registrationNumber  String?
  incorporationDate   DateTime?
  renewalDueDate      DateTime?
  agentName           String?
  totalFeeUsd         Float     @default(0)
  notes               String?
  attachments         String?
  submittedAt         DateTime?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// 隐私合规项
model PrivacyComplianceItem {
  id                  Int       @id @default(autoincrement())
  region              String    // china_gdpr / eu_gdpr / california_ccpa / pipl / etc
  regionName          String    // 中国个保法 / EU GDPR / California CCPA / PIPL
  category            String    // data_collection / data_processing / data_transfer / data_storage / consent / rights / breach
  requirementTitle    String
  requirementDetail   String
  penalty             String?   // 处罚说明
  complianceLevel     String    @default("required") // required / recommended / optional
  deadlineDate        DateTime?
  status              String    @default("pending") // pending / in_progress / completed / overdue
  responsibleDept     String?   // 负责部门
  evidenceUrl         String?   // 合规证明文件
  lastAuditDate       DateTime?
  nextAuditDate       DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// 合同模板
model RegistrationContractTemplate {
  id                  Int       @id @default(autoincrement())
  type                String    // domestic / overseas / privacy / nda / service_agreement / shareholder
  name                String    // 如 "有限责任公司设立协议"
  version             String    @default("1.0")
  content             String    // Markdown 或 HTML 格式的合同正文
  variables           String?   // JSON: [{name:"公司名称",type:"text",required:true,default:"",description:""}]
  jurisdiction        String?   // 适用法域
  language            String    @default("zh-CN")
  usageCount          Int       @default(0)
  isOfficial          Boolean   @default(false)
  tags                String?   // JSON array
  status              String    @default("active")
  createdBy           String?
  contracts           RegistrationContract[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// 合同实例（已填写/签署）
model RegistrationContract {
  id                  Int       @id @default(autoincrement())
  templateId          Int
  template            RegistrationContractTemplate @relation(fields: [templateId], references: [id])
  userId              Int?
  registrationType     String    // domestic / overseas
  registrationId       Int?      // 关联的国内或海外注册ID
  title               String    // 合同标题
  parties             String?   // JSON: [{name,role,signed:false}...]
  filledVariables     String?   // JSON: 已填写的变量值
  content             String?   // 最终生成的合同内容
  fileUrl             String?   // PDF 文件 URL
  status              String    @default("draft") // draft / reviewing / signed / expired / cancelled
  aiGenerated         Boolean   @default(false)
  signedDate          DateTime?
  expiryDate          DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ============================================================
// 用户管理增强模块 (Users Enhancement) - 6 new models
// ============================================================

// 角色定义 (RBAC)
model Role {
  id            Int       @id @default(autoincrement())
  code          String    @unique // super_admin / admin / compliance_officer / kyc_reviewer / operator / viewer / custom_*
  name          String    // 超级管理员 / 合规官 / KYC审核员 / 运营人员 / 只读用户
  description   String?
  permissions   String    // JSON array: ["user:create","user:read","user:update","kyc:approve","role:manage"...]
  isSystem      Boolean   @default(false) // 系统内置角色不可删除
  userCount     Int       @default(0) // 缓存: 关联用户数
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  userRoles     UserRole[]
}

// 用户-角色关联 (多对多)
model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])
  assignedBy Int?    // 分配人ID
  assignedAt DateTime @default(now())
  @@unique([userId, roleId])
}

// 风险评估记录 (AML/CFT)
model UserRiskAssessment {
  id                  Int       @id @default(autoincrement())
  userId              Int       @unique // 每个用户一条最新记录
  overallScore        Int       @default(0) // 综合风险分 0-100
  riskLevel           String    @default("low") // low / medium / high / critical
  identityRisk        Int       @default(0) // 身份风险 0-100
  transactionRisk     Int       @default(0) // 交易风险 0-100
  behavioralRisk      Int       @default(0) // 行为风险 0-100
  geographicRisk      Int       @default(0) // 地域风险 0-100
  sanctionsHit        Boolean   @default(false) // 制裁名单命中
  sanctionsSource     String?   // 制裁来源 ofac/un/eu/uk/etc
  sanctionsMatchName  String?   // 命中名称
  pepFlag             Boolean   @default(false) // 政治敏感人物(PEP)
  pepDetails          String?   // PEP详情JSON
  boDeclared          Boolean   @default(false) // 实控人已声明(Samoa法规要求)
  boInfo              String?   // 实控人信息JSON [{name,nationality,idType,idNo,ownershipPercent}...]
  sourceOfFundsVerified Boolean @default(false) // 资金来源已核实
  sofDocuments        String?   // 资金来源证明文件URLs JSON array
  lastAssessedAt      DateTime  @default(now())
  nextReviewDate      DateTime? // 下次复核日期
  notes               String?   // 风评师备注
  assessedBy          Int?      // 评估人ID
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// 操作审计日志 (Audit Trail - 防篡改)
model AuditLogEnhanced {
  id            Int       @id @default(autoincrement())
  userId        Int?      // 操作人ID (可为系统自动)
  userType      String    @default("admin") // admin / system / api
  action        String    // user.create / user.update / kyc.approve / role.assign / session.terminate / risk.update / login.failed / etc
  targetId      Int?      // 目标对象ID
  targetType    String?   // user / role / kyc / session / config
  description   String?   // 操作描述
  ipAddress     String?
  userAgent     String?
  requestData   String?   // 请求数据摘要(JSON)
  responseData  String?   // 响应数据摘要(JSON)
  statusCode    Int?      // HTTP状态码
  durationMs    Int?      // 执行耗时(ms)
  createdAt     DateTime  @default(now()) // 审计时间戳(不可修改!)
  
  @@index([userId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// 用户会话 (Session Management)
model UserSession {
  id              Int       @id @default(autoincrement())
  userId          Int
  sessionId       String    @unique // JWT session ID or token hash
  deviceType      String    // desktop / mobile / tablet / api
  deviceName      String?   // 如 "Chrome on Windows" 或 "iPhone 15 Pro"
  ipAddress       String
  location        String?   // 城市/国家
  userAgent       String?
  mfaVerified     Boolean   @default(false)
  lastActivityAt  DateTime  @default(now())
  expiresAt       DateTime
  isActive        Boolean   @default(true)
  terminatedAt    DateTime?
  terminateReason String?   // force_logout / password_change / security_risk / expired / etc
  createdAt       DateTime  @default(now())
  
  @@index([userId])
  @@index([isActive])
  @@index([expiresAt])
}

// 登录历史 (Login History)
model LoginHistory {
  id            Int       @id @default(autoincrement())
  userId        Int
  loginMethod   String    @default("password") // password / sms / oauth / sso / mfa
  ipAddress     String
  location      String?
  deviceInfo    String?
  status        String    @default("success") // success / failed / blocked / mfa_required
  failReason    String?   // wrong_password / account_locked / ip_blocked / etc
  mfaStatus     String?   // not_required / passed / failed / skipped
  createdAt     DateTime  @default(now())
  
  @@index([userId])
  @@index([status])
  @@index([ipAddress])
  @@index([createdAt])
}

// ============================================================
// AI 自动化解决方案 — 新增模型 (Phase 1 P1-04)
// 文件存储 / 区块链存证 / 电子签名 / Agent 会话与任务 / LLM 调用日志 / 通知规则
// ============================================================

/// 文件存储记录 — 管理上传至 MinIO 的所有文件元数据
model FileStorage {
  id            Int       @id @default(autoincrement())
  fileName      String    // 原始文件名
  originalName  String    @map("original_name")
  mimeType      String    // MIME 类型 (application/pdf, image/png 等)
  sizeBytes     BigInt    @map("size_bytes")           // 文件大小（字节）
  storagePath   String    @map("storage_path")        // MinIO 对象路径
  hashSha256    String    @unique @map("hash_sha256") // SHA-256 哈希（用于去重和存证）
  bucket        String    @default("smyweb3-files")   // MinIO Bucket 名称
  uploadedBy    Int?      @map("uploaded_by")
  user          User?     @relation(fields: [uploadedBy], references: [id])
  documents     Document[] @relation("DocumentFiles")
  evidences     BlockchainEvidence[] @relation("EvidenceFiles")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([bucket])
  @@index([uploadedBy])
  @@index([createdAt])
  @@map("file_storages")
}

/// 区块链存证记录 — 记录文件/数据的链上存证信息
model BlockchainEvidence {
  id              Int       @id @default(autoincrement())
  fileId          Int       @map("file_id")
  file            FileStorage @relation("EvidenceFiles", fields: [fileId], references: [id])
  fileHash        String    @map("file_hash")            // SHA-256 哈希
  txHash          String    @unique @map("tx_hash")       // 链上交易哈希
  blockNumber     BigInt    @map("block_number")          // 区块号
  contractAddress String    @map("contract_address")     // 合约地址
  chainId         Int       @map("chain_id")             // 链 ID (1=以太坊主网, 137=Polygon, 56=BSC)
  didId           Int?      @map("did_id")
  did             DidIdentity? @relation(fields: [didId], references: [id])
  documents       Document[]  @relation("DocumentEvidences")
  evidenceType    String    @map("evidence_type")        // 'document' | 'signature' | 'report'
  metadata        String?   @map("metadata")             // 额外元数据 (JSON string)
  isVerified      Boolean   @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([fileId])
  @@index([didId])
  @@index([evidenceType])
  @@index([txHash])
  @@map("blockchain_evidences")
}

/// 电子签名记录 — 管理文档的数字签名
model ESignature {
  id              Int       @id @default(autoincrement())
  documentId      Int       @unique @map("document_id")
  document        Document  @relation(fields: [documentId], references: [id])
  signerDid       Int       @map("signer_did")
  signer          DidIdentity @relation(fields: [signerDid], references: [id])
  signatureValue  String    @map("signature_value")     // Base64 编码签名值
  publicKey       String    @map("public_key")          // 签名者公钥
  algorithm       String    @default("ECDSA") @map("algorithm") // 'ECDSA' | 'RSA' | 'EdDSA' | 'SM2'
  signedAt        DateTime  @default(now()) @map("signed_at")
  ipAddress       String?   @map("ip_address")
  userAgent       String?   @map("user_agent")
  isValid         Boolean   @default(true) @map("is_valid")
  revokedAt       DateTime? @map("revoked_at")
  revokeReason    String?   @map("revoke_reason")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([documentId])
  @@index([signerDid])
  @@index([isValid])
  @@map("e_signatures")
}

/// Agent 会话 — 管理 OpenClaw 智能体的运行会话
model AgentSession {
  id              Int       @id @default(autoincrement())
  configId        Int       @map("config_id")
  config          OpenClawAgent @relation(fields: [configId], references: [id])
  userId          Int?      @map("user_id")
  user            User?     @relation(fields: [userId], references: [id])
  status          String    @default("idle") @map("status") // 'idle' | 'running' | 'paused' | 'completed' | 'error'
  currentTask     String?   @map("current_task")
  totalTasks      Int       @default(0) @map("total_tasks")
  completedTasks  Int       @default(0) @map("completed_tasks")
  failedTasks     Int       @default(0) @map("failed_tasks")
  context         String?   @map("context")              // Agent 上下文/记忆 (JSON string)
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  lastHeartbeatAt DateTime  @default(now()) @map("last_heartbeat_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  tasks           AgentTask[]
  llmCallLogs     LlmCallLog[]

  @@index([status])
  @@index([configId])
  @@index([userId])
  @@map("agent_sessions")
}

/// Agent 任务 — 管理 Agent 的具体执行任务
model AgentTask {
  id              Int       @id @default(autoincrement())
  sessionId       Int       @map("session_id")
  session         AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type            String    @map("type")                // 'acquisition' | 'content' | 'analysis' | 'evidence' | 'kyc_review'
  status          String    @default("queued") @map("status") // 'queued' | 'running' | 'success' | 'failed' | 'retrying' | 'cancelled'
  priority        Int       @default(5) @map("priority")  // 1=最高优先级, 10=最低
  payload         String    @map("payload")             // 任务参数 (JSON string)
  result          String?   @map("result")              // 执行结果 (JSON string)
  errorMessage    String?   @map("error_message")
  retryCount      Int       @default(0) @map("retry_count")
  maxRetries      Int       @default(3) @map("max_retries")
  queuedAt        DateTime  @default(now()) @map("queued_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  bpmInstanceId   Int?      @map("bpm_instance_id")    // 关联 BPM 流程实例
  createdBy       Int?      @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([sessionId, status])
  @@index([type, status])
  @@index([status])
  @@map("agent_tasks")
}

/// LLM 调用日志 — 记录每次大模型调用的详细信息（用于成本追踪和性能分析）
model LlmCallLog {
  id              Int       @id @default(autoincrement())
  instanceId      Int       @map("instance_id")
  instance        AiModelInstance @relation(fields: [instanceId], references: [id])
  provider        String    @map("provider")             // 'openai' | 'anthropic' | 'qwen' | 'deepseek'
  model           String    @map("model")               // 'gpt-4o' | 'claude-3.5-sonnet' | 'qwen-max' 等
  promptTokens    Int       @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  latencyMs       Int       @map("latency_ms")          // 响应延迟（毫秒）
  totalCost       Float     @default(0) @map("total_cost") // 本次调用费用（USD）
  success         Boolean   @default(true) @map("success")
  errorCode       String?   @map("error_code")
  errorMessage    String?   @map("error_message")
  cacheHit        Boolean   @default(false) @map("cache_hit")  // 是否命中语义缓存
  userId          Int?      @map("user_id")
  user            User?     @relation(fields: [userId], references: [id])
  sessionId       Int?      @map("session_id")           // 关联 AgentSession
  session         AgentSession? @relation(fields: [sessionId], references: [id])
  requestHash     String?   @map("request_hash")         // 请求内容哈希（用于缓存 key）
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([instanceId])
  @@index([provider])
  @@index([model])
  @@index([createdAt])
  @@index([success])
  @@map("llm_call_logs")
}

/// 通知告警规则 — 定义系统监控告警的通知配置
model NotificationRule {
  id              Int       @id @default(autoincrement())
  name            String                              // 规则名称
  metricName      String    @map("metric_name")         // 监控指标名称
  condition       String                             // 触发条件表达式 ('>100', '<10', '==0')
  thresholdValue  Float     @map("threshold_value")      // 阈值
  // 严重级别: info=信息, warning=警告, critical=严重
  severity        String    @default("warning") @map("severity")
  enabled         Boolean   @default(true) @map("enabled")
  // 通知渠道 (JSON 数组): dingtalk/email/sms/webhook
  channels        String    @default("[\"dingtalk\"]") @map("channels")
  webhookUrl      String?   @map("webhook_url")         // Webhook 回调地址
  // 冷却时间（分钟，防止告警风暴）
  cooldownMinutes Int       @default(30) @map("cooldown_minutes")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  triggerCount    Int       @default(0) @map("trigger_count")
  createdBy       Int       @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([metricName])
  @@index([enabled])
  @@index([severity])
  @@map("notification_rules")
}
