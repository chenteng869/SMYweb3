        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "活跃 Agent 会话数",
      "type": "stat",
      "targets": [
        {
          "exemplar": true,
          "expr": "smyweb3_agent_sessions_active",
          "interval": "",
          "legendFormat": "活跃会话",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
