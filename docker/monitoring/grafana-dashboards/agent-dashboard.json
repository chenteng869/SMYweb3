      "type": "gauge",
      "targets": [
        {
          "exemplar": true,
          "expr": "smyweb3_agent_sessions_active * 100 / 50",
          "interval": "",
          "legendFormat": "利用率",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
