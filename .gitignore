# ==========================================
# 根 .gitignore — MSB-EXCHANGE Web3 Monorepo
# ==========================================

# -------- Dependencies --------
node_modules/
**/node_modules/

# -------- Build outputs (通用) --------
dist/
build/
out/
**/dist/
**/build/
**/out/

# -------- Next.js --------
.next/
**/.next/

# -------- Vite / React --------
.vite/
**/.vite/

# -------- 部署产物 (deploy/ 整目录忽略) --------
deploy/
# 例外: 如果需要把 deploy/ 纳入仓库管理, 移除上一行并按需保留子目录

# -------- 旧版构建产物目录 (兼容历史) --------
admin-dist/
admin-web/
taichu-admin-dashboard/

# -------- 旧版源码目录 (已迁移至 apps/) --------
app/
frontend/
backend/
太初国链-*/
# 例外: 如果需要保留中文目录, 移除上一行

# -------- Environment variables --------
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
!.env.example

# -------- IDE --------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -------- OS --------
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -------- Logs --------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
**/*.log

# -------- Testing & Coverage --------
coverage/
.nyc_output/
**/coverage/
**/.nyc_output/

# -------- Prisma / DB --------
prisma/migrations/
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# -------- Cache & Temp --------
.cache/
.temp/
.tmp/
**/.cache/
**/.temp/
**/.tmp/
.eslintcache
.parcel-cache
**/.eslintcache
**/.parcel-cache

# -------- TypeScript build info --------
*.tsbuildinfo
**/*.tsbuildinfo

# -------- Bundle analyzer --------
.report/
**/.report/

# -------- Optional npm/yarn integrity files --------
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm-store/

# -------- Editor backups --------
*.bak
*.tmp
*.orig
**/*.bak
**/*.tmp
**/*.orig

# -------- Docker --------
.docker/
docker-compose.override.yml

# -------- Misc --------
*.pid
*.seed
*.pid.lock
.pnp.js
