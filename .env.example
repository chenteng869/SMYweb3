# ==========================================
# 根 .env.example — MSB-EXCHANGE Web3 Monorepo
# 复制为 .env 后填入实际值
# ==========================================

# -------- 后端 API 通用配置 --------
NODE_ENV=development
API_PORT=3001
API_BASE_URL=http://localhost:3001

# -------- 数据库 (PostgreSQL) --------
# apps/api/.env 中按相同字段命名
DATABASE_URL=postgresql://user:password@localhost:5432/msb_exchange
DB_HOST=localhost
DB_PORT=5432
DB_NAME=msb_exchange
DB_USER=msb_user
DB_PASSWORD=change_me_in_production

# -------- JWT / 认证 --------
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# -------- CORS --------
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# -------- Redis (可选) --------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -------- H5 移动端 (apps/h5-app) --------
VITE_API_BASE_URL=http://localhost:3001/api
VITE_APP_NAME=MSB-EXCHANGE
VITE_WS_URL=ws://localhost:3001

# -------- 管理后台 Vite 版 (apps/admin-web) --------
VITE_API_PROXY_TARGET=http://localhost:3001

# -------- 管理后台 Next.js legacy 版 (apps/admin-web-legacy) --------
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=MSB-EXCHANGE Admin

# -------- Web3 区块链配置 (可选) --------
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/YOUR_KEY
WEB3_CHAIN_ID=1
WEB3_RPC_URL=

# -------- 日志 / 监控 --------
LOG_LEVEL=info
SENTRY_DSN=
